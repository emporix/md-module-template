{
  "name": "federation-remote",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:stage": "vite --mode stage",
    "build:watch": "tsc -b && vite build --mode dev --watch",
